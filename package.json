{
	"name": "pushwork",
	"version": "2.0.0-preview.2",
	"description": "Bidirectional directory synchronization using Automerge CRDTs",
	"main": "dist/index.js",
	"exports": {
		".": "./dist/index.js"
	},
	"bin": {
		"pushwork": "./dist/cli.js"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"test": "vitest run",
		"test:bail": "vitest run --bail 1",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "eslint src --ext .ts",
		"lint:fix": "eslint src --ext .ts --fix",
		"clean": "rm -rf dist",
		"prepack": "pnpm run build",
		"start": "node dist/cli.js",
		"typecheck": "tsc --noEmit"
	},
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=8.0.0"
	},
	"keywords": [
		"automerge",
		"sync",
		"crdt",
		"collaboration",
		"filesystem"
	],
	"author": "Peter van Hardenberg",
	"license": "MIT",
	"files": [
		"dist",
		"patches"
	],
	"pnpm": {
		"patchedDependencies": {
			"@automerge/automerge-repo@2.6.0-subduction.15": "patches/@automerge__automerge-repo@2.6.0-subduction.15.patch"
		}
	},
	"dependencies": {
		"@automerge/automerge": "^3.2.6",
		"@automerge/automerge-repo": "2.6.0-subduction.15",
		"@automerge/automerge-repo-network-websocket": "2.6.0-subduction.15",
		"@automerge/automerge-repo-storage-nodefs": "2.6.0-subduction.15",
		"@automerge/automerge-subduction": "0.8.1",
		"@commander-js/extra-typings": "^14.0.0",
		"chalk": "^5.3.0",
		"commander": "^14.0.2",
		"debug": "^4.4.3",
		"diff": "^8.0.2",
		"glob": "^10.3.0",
		"ignore": "^5.3.0",
		"mime-types": "^2.1.35",
		"ora": "^7.0.1"
	},
	"devDependencies": {
		"@types/debug": "^4.1.13",
		"@types/diff": "^5.0.3",
		"@types/mime-types": "^2.1.1",
		"@types/node": "^20.0.0",
		"@types/tmp": "^0.2.4",
		"@vitest/coverage-v8": "^2.1.0",
		"fast-check": "^4.3.0",
		"tmp": "^0.2.1",
		"tsx": "^4.19.2",
		"typescript": "^5.2.0",
		"vitest": "^2.1.0"
	}
}
